{
  "manifest_version": 3,
  "name": "NexAlgo",
  "version": "1.0.0",
  "description": "Show NexAlgo problem details and submit new coding questions for review.",
  "permissions": ["sidePanel", "storage"],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://www.geeksforgeeks.org/*",
    "https://identitytoolkit.googleapis.com/*",
    "https://securetoken.googleapis.com/*",
    "https://*.run.app/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["src/content/leetcode.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.geeksforgeeks.org/problems/*"],
      "js": ["src/content/gfg.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Open NexAlgo"
  }
}

# BuzzCart repo-level local overrides.
# Backend application secrets belong in backend/.env, not here.

BUZZCART_BACKEND_PORT=8080
BUZZCART_FRONTEND_PORT=8081
BUZZCART_REDIS_PORT=6379
BUZZCART_CHATBOT_PORT=8001
BUZZCART_OLLAMA_PORT=11434

# Keep frontend origins environment-driven.
BUZZCART_ALLOWED_FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:8080,http://localhost:8081

# Docker-only internal Redis URL. Set blank if you want backend cache disabled.
BUZZCART_DOCKER_REDIS_URL=redis://redis:6379/0

# Optional local chatbot overlay values. Production keeps chatbot disabled.
BUZZCART_ENABLE_CHATBOT=false
OLLAMA_MODEL=mistral
TORCH_WHEEL_CHANNEL=cu128

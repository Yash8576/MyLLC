# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Models
EMBEDDING_MODEL_NAME=BAAI/bge-m3
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
MODEL_DEVICE=auto
MODEL_DEVICE_INDEX=0
ENABLE_TF32=true
EMBEDDING_BATCH_SIZE=32
RERANK_BATCH_SIZE=24
OLLAMA_MODEL=mistral

# PostgreSQL (for chat history)
DATABASE_URL=postgresql://user:password@postgres:5432/like2share
# Firebase Cloud SQL via Auth Proxy example (recommended local setup)
# DATABASE_URL=postgresql://buzzcart_chatbot_ro:REPLACE_CHATBOT_PASSWORD@127.0.0.1:5432/buzzcart-daeb6-database?sslmode=disable
CHAT_HISTORY_TABLE=chat_messages

# RAG Configuration
CHUNK_SIZE_TOKENS=400
CHUNK_OVERLAP_TOKENS=80
TOP_K_RESULTS=10
RETRIEVAL_CANDIDATE_POOL=24
LEXICAL_SEARCH_LIMIT=24
RERANK_TOP_K=3
SENTENCE_TOP_K=8
NEIGHBOR_WINDOW=1
MAX_EVIDENCE_BLOCKS=3
DIRECT_SEARCH_TOP_K=14
DIRECT_MATCH_MIN_SCORE=0.58

# Document Storage
DOCUMENTS_PATH=/app/data/documents
VECTOR_STORE_DIR=/app/data/vector_store
MODEL_CACHE_DIR=/app/models/cache
ALLOWED_EXTENSIONS=[".pdf"]
